/* 1020 type user buffer */

DEFINE_STRUCT  USER_BUFFER  10
  ELEM         1  SHORT    max_avgs                              none
  ELEM         1  SHORT    first_bin                             none
  ELEM         1  SHORT    n_bins                                none
  ELEM        20  SHORT    avg_uv                                mm/s
  ELEM         1  SHORT    set                                   deg*E-1
  ELEM         1  SHORT    drift                                 kts*E-2
  ELEM         1  SHORT    position_source                       none
  ELEM         1  SHORT    dr_time                               s
  ELEM         1  LONG     time                                  s
  ELEM         1  STRUCT   fix                                   none

DEFINE_STRUCT  fix  21
  ELEM         1  SHORT    ref_u                                 mm/s
  ELEM         1  SHORT    ref_v                                 mm/s
  ELEM         1  SHORT    ref_count                             none
  ELEM         1  LONG     pc_time                               s
  ELEM         1  LONG     fix_time                              s
  ELEM         1  LONG     lon                                   sec*E-2
  ELEM         1  LONG     lat                                   sec*E-2
  ELEM         1  LONG     antenna                               m*E-1
  ELEM         1  SHORT    dr_dist                               nm*E-2
  ELEM         1  SHORT    dr_dir                                deg*E-1
  ELEM         1  SHORT    sigma_lon                             m
  ELEM         1  SHORT    sigma_lat                             m
  ELEM         1  SHORT    sat_id                                none
  ELEM         1  BYTE     used                                  none
  ELEM         1  BYTE     q1                                    none
  ELEM         1  BYTE     q2                                    none
  ELEM         1  BYTE     q3                                    none
  ELEM         1  BYTE     elevation                             deg
  ELEM         1  BYTE     iterations                            none
  ELEM         1  BYTE     dop_count                             none
  ELEM         1  BYTE     spare                                 none

